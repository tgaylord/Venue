# Clerk (https://dashboard.clerk.com → API keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Neon Postgres (https://neon.tech → connection string, pooled)
DATABASE_URL=

# Cloudflare R2 (S3-compatible) — private bucket for condition photos
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Resend (https://resend.com → API keys). Verify a sending domain's DNS early.
RESEND_API_KEY=
EMAIL_FROM="VenueDash <noreply@venuedash.com>"

# Canonical app origin for links in transactional emails (owner dashboard, renter status link).
# Server-only runtime var (not NEXT_PUBLIC — never needed client-side, and stays changeable without a rebuild).
# Set on the Vercel PRODUCTION scope only (e.g. https://venuedash.com). Leave UNSET on Preview and in dev:
# the action then falls back to the request host, which is the correct per-deployment / localhost URL.
APP_URL=
