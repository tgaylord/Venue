# Enforce package.json "engines" — this project MUST build on Node 20.x.
# CI and Vercel build on Node 20; generating package-lock.json under a different
# Node major (e.g. 24) restructures esbuild's tree and breaks `npm ci` in CI.
# engine-strict makes npm refuse to run on the wrong Node instead of silently
# producing an incompatible lockfile. Run `nvm use 20` before npm commands.
engine-strict=true
